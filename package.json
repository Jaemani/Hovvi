{
  "name": "hovvi",
  "version": "0.1.0",
  "description": "Catch and resume remote development sessions from mobile devices.",
  "type": "module",
  "homepage": "https://github.com/Jaemani/Hovvi#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Jaemani/Hovvi.git"
  },
  "bugs": {
    "url": "https://github.com/Jaemani/Hovvi/issues"
  },
  "bin": {
    "hovvi": "./bin/hovvi"
  },
  "files": [
    "bin",
    "src",
    "scripts",
    "native/mosh-core/README.md",
    "native/mosh-core/Makefile",
    "native/mosh-core/adapter",
    "native/mosh-core/include",
    "native/mosh-core/src/hovvi_mosh_core_unavailable.c",
    "native/mosh-core/tests/abi_smoke.c",
    "native/mosh-core/tests/packet_io_smoke.cc",
    "native/mosh-core/tests/relay_session_smoke.cc",
    "native/mosh-core/tests/c_abi_driver_smoke.cc",
    "README.md",
    "CHANGELOG.md",
    "docs",
    "packaging",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test",
    "check": "node --check bin/hovvi && node --check src/*.js && node --check scripts/*.js",
    "native:check": "make -C native/mosh-core check",
    "native:adapter-check": "make -C native/mosh-core adapter-check",
    "native:upstream-check": "make -C native/mosh-core upstream-check",
    "native:upstream-lib": "make -C native/mosh-core upstream-lib",
    "native:mosh-server-harness-check": "node scripts/native-mosh-server-harness-check.js",
    "native:relay-attach-check": "node scripts/native-relay-attach-check.js",
    "native:relay-process-attach-check": "node scripts/native-relay-process-attach-check.js",
    "ios:simulator-preflight": "node scripts/ios-simulator-preflight.js",
    "ios:simulator-build-check": "node scripts/ios-simulator-build-check.js",
    "ios:simulator-app-bundle-check": "node scripts/ios-simulator-app-bundle-check.js",
    "ios:simulator-install-check": "node scripts/ios-simulator-install-check.js",
    "ios:simulator-launch-check": "node scripts/ios-simulator-launch-check.js",
    "ios:simulator-screenshot-check": "node scripts/ios-simulator-screenshot-check.js",
    "ios:upstream-cabi-link-check": "node scripts/ios-upstream-cabi-link-check.js",
    "mosh:vendor:verify": "node scripts/mosh-vendor-verify.js",
    "package:boundary-check": "node scripts/package-boundary-check.js",
    "prepublishOnly": "npm run check && npm test && npm run native:check && npm run native:adapter-check && npm run mosh:vendor:verify && npm run package:boundary-check"
  },
  "keywords": [
    "tmux",
    "mosh",
    "remote-development",
    "mobile",
    "terminal"
  ],
  "author": "Jaemani",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "ws": "^8.18.0"
  }
}
